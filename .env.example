# Telnetvision producer config (home/capture side). Copy to .env and edit.
#   cp .env.example .env
# .env is gitignored — never commit your real TOKEN.

# Where the fanout service lives (your cloud/BBS box) and the shared ingest token.
BBS_HOST=your.bbs.hostname
BBS_PORT=7600
TOKEN=CHANGE_ME_run_openssl_rand_hex_16

# Channel name. The service routes by channel: one publisher per channel, many
# door subscribers. Must match the door's `channel=` in door.ini (also "cam" by
# default). Pick a different name to run a second feed alongside the first
# (e.g. CHANNEL=desk for a screencap channel).
CHANNEL=cam

# Frame grid (cells). 80x24/80x25 = a standard BBS screen.
COLS=80
ROWS=24

# Transport. TLS=1 encrypts; INSECURE=1 skips cert verification (self-signed certs).
TLS=1
INSECURE=1

# Subtitle feed: the producer broadcasts this file's last line (see caption-mic.sh).
CAPTION_FILE=/tmp/caption.txt

# Optional: which audio input whisper-stream transcribes. Either an SDL device
# index (fast, but the integer shifts when AirPods/devices toggle) or a
# case-insensitive device-name substring (resilient; resolved at startup).
# Run  LIST=1 ./caption-mic.sh  to see the current device list cleanly.
# CAPTURE=2
# CAPTURE="usb audio"

# Optional: video source — camera | test | - (stdin) | <device index> | <file/URL>
# SOURCE=camera

# Optional: mirror flip — auto-mirrors only the default webcam; 0 to force off.
# FLIP=0
